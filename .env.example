# pwa-snapshot environment variables
# Copy to .env and fill in your values, then:
#   docker run --rm --env-file .env -v $(pwd)/dist:/output pwa-snapshot

# ── Required ───────────────────────────────────────────────────────────────────
# URL of the PWA page or manifest file
PWA_URL=https://myapp.example.com

# ── Optional ───────────────────────────────────────────────────────────────────

# Path INSIDE the container where the zip will be written.
# Change the host-side path with the -v mount, not this variable.
OUTPUT_PATH=/output/pwa-snapshot.zip

# Comma-separated icon sizes (px) to generate when a size is missing.
# Requires sharp (included in the Docker image).
ICON_SIZES=48,72,96,144,192,512

# Set to "1" or "true" to skip icon resizing entirely.
NO_RESIZE=false

# HTTP timeout in milliseconds for each fetch request.
REQUEST_TIMEOUT=15000

# Set to "1" or "true" to print every fetched URL.
VERBOSE=false
